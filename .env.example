# =============================================================================
# .env.local — copy this file to .env.local and fill in real values.
# .env.local is git-ignored. Never commit secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Firebase (client) — REQUIRED for build and app (login, Firestore, Storage)
# Get these from Firebase Console → Project settings → Your apps → Web app config
# Use NEXT_PUBLIC_* so the browser and scripts/generate-firebase-config.js can use them.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional (Analytics)
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin — alternative: base64-encoded service account JSON (Premium Studio / API)
# FIREBASE_SERVICE_ACCOUNT_KEY_BASE64=<base64 of full JSON>

# -----------------------------------------------------------------------------
# Firebase Admin (server) — REQUIRED for Premium Studio (captions, usage) and
# any API that verifies Firebase ID tokens or uses Admin SDK.
# Use the SAME Firebase project as your client (NEXT_PUBLIC_FIREBASE_*).
#
# Get the key: Firebase Console → Project settings → Service accounts →
# Generate new private key → download the JSON file.
#
# Set ONE of:
#   FIREBASE_SERVICE_ACCOUNT_JSON_PATH = path to JSON file (e.g. ./secrets/firebase-key.json) — avoids .env parsing issues
#   FIREBASE_SERVICE_ACCOUNT_JSON     = full JSON as one line (escape quotes if in shell)
#   FIREBASE_SERVICE_ACCOUNT_KEY_BASE64 = base64-encoded JSON (good for Vercel/env)
# -----------------------------------------------------------------------------
# Option A — JSON string (one line, no line breaks in the value):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}
#
# Option B — Base64 (encode the JSON file: base64 -i path/to/key.json | tr -d '\n'):
# FIREBASE_SERVICE_ACCOUNT_KEY_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...

# -----------------------------------------------------------------------------
# Stripe — REQUIRED for subscription, tips, unlock, customer portal, webhook
# Get from Stripe Dashboard → Developers → API keys
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
# Subscription: Dashboard → Products → [Your product] → Price → ID (starts with price_)
STRIPE_PRICE_ID_MONTHLY=
# Or alternative name the code accepts:
# STRIPE_SUBSCRIPTION_PRICE_ID=

# Webhook: Dashboard → Developers → Webhooks → Add endpoint → Signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# Premium Studio: AI captions and chat session suggestions (Gemini)
# GEMINI_API_KEY=   # or GOOGLE_API_KEY=
# Rate limiting (optional; in-memory fallback if unset)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Set to "false" to hide the Treats store nav and show "Coming soon" on /treats (set "true" to enable; default when unset: enabled)
# NEXT_PUBLIC_TREATS_STORE=true
# Base URL for Stripe success/cancel redirects (defaults to https://stormijxo.com if unset)
# PUBLIC_APP_URL=http://localhost:3000
